# --- Microsoft Foundry credentials ----------------------------------
# Copy this file to ".env" and fill in the values from your team's
# block in foundry_credentials.txt (or from the Azure portal).
#
#   cp .env.template .env
# --------------------------------------------------------------------

# Azure OpenAI–compatible endpoint of your Foundry resource.
# Format: https://<resource-name>.openai.azure.com/
FOUNDRY_ENDPOINT=https://YOUR-FOUNDRY-RESOURCE.openai.azure.com/

# Foundry resource API key (key1 or key2).
FOUNDRY_API_KEY=replace-with-your-api-key

# Foundry Project endpoint — required for the file-search agent example.
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://YOUR-FOUNDRY-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT

# Azure OpenAI REST API version.
FOUNDRY_API_VERSION=2024-10-21

# Deployment names (must match what was provisioned on the resource).
FOUNDRY_DEPLOYMENT_CHAT=gpt-4o-mini
FOUNDRY_DEPLOYMENT_AGENT=gpt-4o-mini
FOUNDRY_DEPLOYMENT_VISION=gpt-4o